---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import myPhoto from "../assets/me.png";

const posts = (await getCollection("blog"))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);

const isMaintenance = import.meta.env.PUBLIC_MAINTENANCE_MODE === "true";
---

{
    isMaintenance ? (
        <BaseLayout title="Coming Soon">
            <div class="h-[60vh] flex flex-col justify-center items-center text-center">
                <div class="w-12 h-12 border-2 border-gold rounded-full mb-8 animate-pulse" />
                <h1 class="text-2xl font-medium text-zinc-100 mb-4 tracking-tight">
                    We'll Be Back Soon!
                </h1>
                <p class="text-zinc-500 max-w-xs text-sm leading-relaxed">
                    Expect something special.
                </p>
                <div class="mt-12 text-[10px] font-mono text-gold/50 uppercase tracking-[0.3em]">
                    2026 — T.N. Hamilton
                </div>
            </div>
        </BaseLayout>
    ) : (
        <BaseLayout title="T.N. Hamilton | Home">
            <section class="mt-16 mb-24">
                <div class="flex items-center gap-8 md:gap-20 mb-8">
                    <img
                        src={myPhoto.src}
                        alt="Tomis Hamilton"
                        class="w-28 h-28 rounded-full object-cover border-2 border-zinc-800 shadow-xl"
                    />
                    <h1 class="text-lg md:text-3xl lg:text-4xl font-semibold tracking-tight text-zinc-100">
                        <span class="text-gold">Hi! </span>
                        I'm Tomis Hamilton
                    </h1>
                </div>
                <p class="text-lg text-zinc-400 leading-relaxed max-w-2xl">
                    I'm a Computer Science major with a focus in Cybersecurity.
                    I enjoy researching personal privacy rights and how
                    Cybersecurity can influence policy. I wrote my first{" "}
                    <code>Hello World!</code> program 13 years ago. Today, I
                    continue to develop full stack applications, learn new
                    paradigms, and attempt to not break my Linux configuration.
                    I am the founder of{" "}
                    <a
                        href="https://cyberbeans.org"
                        class="text-zinc-200 underline decoration-gold/50 underline-offset-4"
                    >
                        Cyberbeans LLC
                    </a>
                    . In my free time, I enjoy snowboarding, playing video
                    games, leisure reading, and writing out my thoughts.
                </p>
            </section>

            <section>
                <div class="flex items-baseline justify-between mb-10 border-b border-zinc-800 pb-2">
                    <h2 class="text-xs uppercase tracking-[0.2em] text-gold font-bold">
                        Latest Writing
                    </h2>
                    <a
                        href="/blog"
                        class="text-xs text-zinc-500 hover:text-gold transition-colors underline underline-offset-4 decoration-zinc-700"
                    >
                        View All
                    </a>
                </div>

                <div class="space-y-12">
                    {posts.length > 0 ? (
                        posts.map((post) => (
                            <article class="group relative">
                                <a href={`/blog/${post.slug}`} class="block">
                                    <div class="flex flex-col md:flex-row md:items-baseline justify-between mb-2">
                                        <h3 class="text-xl text-zinc-200 group-hover:text-gold transition-colors font-medium">
                                            {post.data.title}
                                        </h3>
                                        <time class="text-zinc-600 font-mono text-xs uppercase tracking-widest">
                                            {post.data.pubDate.toLocaleDateString(
                                                "en-us",
                                                {
                                                    month: "short",
                                                    day: "numeric",
                                                    year: "numeric",
                                                },
                                            )}
                                        </time>
                                    </div>
                                    <p class="text-sm text-zinc-500 max-w-2xl line-clamp-2 leading-relaxed">
                                        {post.data.description ||
                                            "Click to read the full story..."}
                                    </p>
                                </a>
                            </article>
                        ))
                    ) : (
                        <p class="text-zinc-600 italic">No posts yet.</p>
                    )}
                </div>
            </section>

            <section class="mt-32">
                <div class="flex items-baseline justify-between mb-12 border-b border-zinc-800 pb-2">
                    <h2 class="text-xs uppercase tracking-[0.2em] text-gold font-bold">
                        Featured Projects
                    </h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
                    <div class="group cursor-pointer">
                        <div class="aspect-[16/10] bg-zinc-900 rounded-lg overflow-hidden border border-zinc-800 group-hover:border-gold/30 transition-all">
                            <div class="w-full h-full bg-gradient-to-br from-gold/10 to-transparent flex items-center justify-center text-zinc-700 font-mono text-xs uppercase tracking-widest">
                                [Project Preview]
                            </div>
                        </div>
                        <div class="mt-6">
                            <h3 class="text-lg text-zinc-100 font-medium group-hover:text-gold transition-colors">
                                Network Visualization
                            </h3>
                            <p class="text-zinc-500 text-sm mt-2 leading-relaxed">
                                My senior capstone brings network analysis to a
                                virtual reality frontend through Unity. This
                                project bridges a Clickhouse database with a
                                PCAP parser written in Rust with anomaly
                                detection via Zeek so that the barrier of entry
                                for aspiring network analysts would be lowered.
                            </p>
                        </div>
                    </div>

                    <div class="group cursor-pointer md:mt-24">
                        <div class="aspect-[16/10] bg-zinc-900 rounded-lg overflow-hidden border border-zinc-800 group-hover:border-gold/30 transition-all">
                            <div class="w-full h-full bg-gradient-to-tr from-gold/10 to-transparent flex items-center justify-center text-zinc-700 font-mono text-xs uppercase tracking-widest">
                                [Project Preview]
                            </div>
                        </div>
                        <div class="mt-6">
                            <h3 class="text-lg text-zinc-100 font-medium group-hover:text-gold transition-colors">
                                PerFin App
                            </h3>
                            <p class="text-zinc-500 text-sm mt-2 leading-relaxed">
                                This project seeks to address the agressive
                                practices of personal finance apps. This project
                                was built using React Native, Node.js, and the
                                Plaid API and was deployed to iOS.
                            </p>
                        </div>
                    </div>
                </div>
            </section>
        </BaseLayout>
    )
}
